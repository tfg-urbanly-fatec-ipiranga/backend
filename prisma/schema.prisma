generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pg_stat_statements, pg_trgm, pgcrypto, supabase_vault, uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model User {
  id        String     @id @default(uuid())
  firstName String
  lastName  String
  username  String     @unique
  email     String     @unique
  password  String
  role      Role       @default(USER)
  avatar    String?
  birthDate DateTime
  active    Boolean    @default(true)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  favorites Favorite[]
  reviews   Review[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  iconColor   String?
  description String?
  active      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  places      Place[]
}

model Place {
  id          String                 @id @default(uuid())
  name        String
  description String?
  address     String?
  city        String?
  openingTime String
  closingTime String
  latitude    Float
  longitude   Float
  active      Boolean                @default(true)
  deletedAt   DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  categoryId  String?
  embedding   Unsupported("vector")?
  workingDays String?
  priceLevel  PriceLevel             @default(ONE)
  favorites   Favorite[]
  category    Category?              @relation(fields: [categoryId], references: [id])
  photos      PlacePhoto[]
  placeTags   PlaceTag[]
  reviews     Review[]
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  active    Boolean    @default(true)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  placeTags PlaceTag[]
}

model PlaceTag {
  placeId   String
  tagId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  place     Place    @relation(fields: [placeId], references: [id])
  tag       Tag      @relation(fields: [tagId], references: [id])

  @@id([placeId, tagId])
}

model Review {
  id        String    @id @default(uuid())
  rating    Int
  comment   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  placeId   String
  active    Boolean   @default(false)
  place     Place     @relation(fields: [placeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, placeId])
}

model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, placeId])
}

model PlacePhoto {
  id        String    @id @default(uuid())
  url       String
  caption   String?
  isPrimary Boolean   @default(false)
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  placeId   String
  place     Place     @relation(fields: [placeId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum PriceLevel {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}
